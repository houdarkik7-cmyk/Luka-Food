# =============================================================================
# Luka Food — Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env وعدّل القيم

# PostgreSQL connection string
# format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://luka:your_secure_password@localhost:5432/luka_food

# API server port
PORT=5000

# Frontend API URL (تستخدم في Vite)
VITE_API_URL=http://localhost:5000

# PostgreSQL password (تستخدم في docker-compose.yml)
POSTGRES_PASSWORD=your_secure_password
