# =============================================================================
# Luka Food — Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env وعدّل القيم

# Supabase PostgreSQL connection string
# احصل عليها من: Project Settings → Database → Connection string
# تنسيق الاتصال المباشر:
# postgresql://postgres:your_password@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
# تنسيق الاتصال المجمّع (PgBouncer, port 6543):
# postgresql://postgres.[PROJECT_REF]:your_password@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=postgresql://postgres:your_supabase_password@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Local PostgreSQL (تطوير محلي)
# DATABASE_URL=postgresql://luka:luka123@localhost:5432/luka_food

# API server port
PORT=5000

# Frontend API URL (تستخدم في Vite)
VITE_API_URL=http://localhost:5000

# PostgreSQL password (تستخدم في docker-compose.yml للتطوير المحلي)
POSTGRES_PASSWORD=your_secure_password
